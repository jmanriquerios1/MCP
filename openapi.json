{
  "openapi": "3.0.1",
  "info": {
    "title": "Learn Catalog MCP",
    "version": "1.0.0",
    "description": "MCP server exposing Microsoft Learn catalog."
  },
  "servers": [
    {
      "url": "https://mcp-learn-catalog-app-azevddenc4cmdzdp.westeurope-01.azurewebsites.net"
    }
  ],
  "paths": {
    "/v1/actions/search-courses": {
      "post": {
        "summary": "Search the Microsoft Learn catalog",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "search": { "type": "string" },
                  "locale": { "type": "string", "default": "en-us" }
                },
                "required": ["search"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
